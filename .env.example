# Configuration for the QA suite. Copy to .env and adjust if needed:
#   cp .env.example .env
#
# Base URL of the running Juice Shop instance under test. This is the only
# value the suite needs. CI sets it too.
BASE_URL=http://localhost:3000

# Note: there is no database connection string. The db layer copies Juice Shop's
# SQLite file out of the container with `docker compose cp` and reads the copy,
# and there are no seeded-account credentials, because tests register their own
# users per run.
